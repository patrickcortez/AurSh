<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:AvaloniaEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="AurShell.ISE.MainWindow"
        Title="AurSh ISE"
        Background="{DynamicResource TokyoBackground}"
        Foreground="{DynamicResource TokyoForeground}"
        MinWidth="400" MinHeight="300">

    <Grid RowDefinitions="Auto, *, Auto, 200">
        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{DynamicResource TokyoPanelBg}" BorderBrush="{DynamicResource TokyoBorder}" BorderThickness="0,0,0,1" Padding="10,5">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Name="RunButton" Content="▶ Run Script" Background="{DynamicResource TokyoFunction}" Foreground="{DynamicResource TokyoBackground}" FontWeight="Bold" Click="RunButton_Click"/>
                <Button Name="ClearButton" Content="Clear Output" Background="{DynamicResource TokyoComment}" Foreground="{DynamicResource TokyoForeground}" Click="ClearButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Editor -->
        <AvaloniaEdit:TextEditor Name="Editor" Grid.Row="1"
                                 FontFamily="Cascadia Code,Consolas,Menlo,Monospace"
                                 ShowLineNumbers="True"
                                 Background="{DynamicResource TokyoBackground}"
                                 Foreground="{DynamicResource TokyoForeground}" />

        <!-- Splitter -->
        <GridSplitter Grid.Row="2" Background="{DynamicResource TokyoBorder}" ResizeDirection="Rows" Height="4"/>

        <!-- Output Console -->
        <Border Grid.Row="3" Background="{DynamicResource TokyoPanelBg}" BorderBrush="{DynamicResource TokyoBorder}" BorderThickness="0,1,0,0">
            <ScrollViewer Name="OutputScroll">
                <TextBlock Name="OutputText" FontFamily="Cascadia Code,Consolas,Menlo,Monospace" Margin="10" TextWrapping="Wrap" />
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
